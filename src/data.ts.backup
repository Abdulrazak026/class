          { "question": "Interview: A stakeholder asks for 'everything' in a report. How do you handle this?", "options": ["Give them everything", "Ask what specific decisions they need to make, then build a focused report around those decisions", "Refuse and build what you want", "Build separate reports for every metric"], "correctAnswerIndex": 1 },
          { "question": "Interview: What's the minimum viable dashboard you'd build before iterating?", "options": ["A fully polished dashboard", "One chart answering the primary business question plus one filter/slicer", "Just raw data", "At least 10 charts"], "correctAnswerIndex": 1 },
          { "question": "Interview: How do you test whether your BI report is actually useful to its audience?", "options": ["Assume it's useful", "Watch a stakeholder try to use it without guidance — note where they get confused and iterate", "Ask if they like the colors", "Check the number of views"], "correctAnswerIndex": 1 }
