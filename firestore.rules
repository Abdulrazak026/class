rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Access codes — no public reads, validated updates only
    match /accessCodes/{codeHash} {
      allow read: if false;
      allow list: if false;
      allow create: if false;
      allow update: if request.resource.data.status == 'used'
        && request.resource.data.deviceId is string
        && request.resource.data.userId is number;
      allow delete: if false;
    }

    // Config — admin only
    match /config/{docId} {
      allow read: if false;
      allow list: if false;
      allow write: if false;
    }

    // User registry — validate doc structure on read (exists + has deviceId)
    match /userRegistry/{userId} {
      allow read: if resource.data.deviceId is string;
      allow create: if request.resource.data.deviceId is string
        && request.resource.data.deviceId.size() > 0;
      allow update: if false;
      allow delete: if false;
    }

    // Progress sync — validate path userId matches the data owner
    match /progress/{userId} {
      allow read: if true;
      allow write: if userId == '1' || userId == '2'
        && request.resource.data.completedTasks is list
        && request.resource.data.userCode is string;
    }

    // Study room chat — create only with validation
    match /chat/{docId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
        && request.resource.data.user is string
        && request.resource.data.text.size() <= 10000
        && request.resource.data.user.size() <= 100;
      allow update: if false;
      allow delete: if false;
    }

    // Topic comments — create only with validation
    match /topicComments/{docId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
        && request.resource.data.user is string
        && request.resource.data.topicId is string
        && request.resource.data.text.size() <= 5000;
      allow update: if false;
      allow delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
