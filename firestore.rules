rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Access codes — readable by ID only, validated updates
    match /accessCodes/{codeHash} {
      allow read: if true;
      allow list: if false;
      allow create: if false;
      allow update: if (request.resource.data.status == 'used' || request.resource.data.status == 'revoked')
        && request.resource.data.deviceId is string
        && request.resource.data.userId is number;
      allow delete: if false;
    }

    // Config — readable by ID only, no writes from client
    match /config/{docId} {
      allow read: if true;
      allow list: if false;
      allow write: if false;
    }

    // User registry — validate deviceId
    match /userRegistry/{userId} {
      allow read: if true;
      allow write: if request.resource.data.deviceId is string;
    }

    // Progress sync — validate is object
    match /progress/{userId} {
      allow read: if true;
      allow write: if request.resource.data is map;
    }

    // Study room chat — validate required fields
    match /chat/{docId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
        && request.resource.data.user is string
        && request.resource.data.text.size() <= 10000
        && request.resource.data.user.size() <= 100;
      allow update: if false;
      allow delete: if false;
    }

    // Topic comments — validate required fields
    match /topicComments/{docId} {
      allow read: if true;
      allow create: if request.resource.data.text is string
        && request.resource.data.user is string
        && request.resource.data.topicId is string
        && request.resource.data.text.size() <= 5000;
      allow update: if false;
      allow delete: if false;
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
